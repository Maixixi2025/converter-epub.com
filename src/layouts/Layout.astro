---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  datePublished?: string;
  dateModified?: string;
  lang?: string;
  alternateUrls?: { lang: string; url: string }[];
}

const {
  title,
  description = 'Free online EPUB converter. Convert DOCX, HTML, TXT to EPUB instantly in your browser. No server upload, 100% private.',
  canonicalUrl = 'https://converter-epub.com/',
  ogType = 'website',
  datePublished,
  dateModified,
  lang = 'en',
  alternateUrls = [],
} = Astro.props;

// JSON-LD structured data
const jsonLd: any[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    'name': 'converter-epub.com',
    'url': 'https://converter-epub.com/',
    'description': 'Free online EPUB converter. Convert DOCX, HTML, TXT to EPUB in your browser.',
  },
];

if (ogType === 'article' && datePublished) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'Article',
    'headline': title,
    'description': description,
    'url': canonicalUrl,
    'datePublished': datePublished,
    'dateModified': dateModified || datePublished,
    'author': {
      '@type': 'Person',
      'name': 'Jason Mai',
      'url': 'https://about.me/jasonxmai',
    },
    'publisher': {
      '@type': 'Organization',
      'name': 'converter-epub.com',
      'logo': {
        '@type': 'ImageObject',
        'url': 'https://converter-epub.com/og-image.png',
        'width': 1200,
        'height': 630,
      },
    },
  });
}
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="converter-epub.com" href="/sitemap-index.xml" />
    {alternateUrls.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={alt.url} />
    ))}
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="converter-epub.com" />
    <meta property="og:image" content="https://converter-epub.com/og-image.png" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://converter-epub.com/og-image.png" />
    <meta name="twitter:site" content="@converter_epub" />
    <link rel="stylesheet" href="/styles/global.css" />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
    <footer style="max-width:800px;margin:3rem auto 2rem;padding:1.5rem 1rem;border-top:1px solid #e5e7eb;text-align:center;font-size:0.875rem;color:#6b7280;">
      <p>
        <a href="https://about.me/jasonxmai" rel="me noopener" target="_blank" style="color:#4f46e5;text-decoration:underline;">About the Author</a>
        · converter-epub.com is built and maintained by Jason Mai
      </p>
    </footer>
  </body>
</html>
